# ── Production config for docker compose ─────────────────────────────────
# Copy to `.env` (gitignored) on the VPS and fill in. `docker compose` reads
# this file automatically for ${VAR} interpolation and build args.

# Domains (DNS A/AAAA records must already point at the VPS).
APP_DOMAIN=app.example.com
API_DOMAIN=api.example.com

# Web build-time public URLs (inlined into the JS bundle — rebuild on change).
# Must be the PUBLIC api/mirror URLs the browser will call.
NEXT_PUBLIC_PROXY_URL=https://api.example.com
# Leave empty unless you enable the mobile login mirror.
NEXT_PUBLIC_MIRROR_URL=

# Proxy secrets & cookies.
# Generate a strong secret, e.g.:  openssl rand -hex 32
SESSION_SECRET=change-me-to-a-random-32-char-secret
# Parent domain (leading dot) so the session cookie is shared across
# app.<domain> and api.<domain>. Must cover both subdomains.
COOKIE_DOMAIN=.example.com
# HTTPS in prod → secure cookies on.
COOKIE_SECURE=true
# CORS allowlist — the public app origin(s), comma-separated.
PWA_ORIGINS=https://app.example.com

# SNCF upstream + app version (defaults are fine).
SNCF_BACKEND_URL=https://www.maxactif-tgvinoui.sncf
APP_VERSION=2.54.2

# Optional — mobile login mirror (advanced; see Caddyfile). Leave blank to skip.
# MIRROR_HOST=m.example.com
