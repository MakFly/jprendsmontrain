# Auto-HTTPS reverse proxy. Domains come from the env (APP_DOMAIN / API_DOMAIN).
# Caddy obtains + renews Let's Encrypt certs automatically (ports 80/443 open).

{$APP_DOMAIN} {
	encode zstd gzip
	reverse_proxy web:3020
}

{$API_DOMAIN} {
	encode zstd gzip
	reverse_proxy proxy:3333
}

# ── Optional: mobile no-copy-paste login mirror ──────────────────────────
